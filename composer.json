{
  "name": "heliomarpm/linq-php",
  "description": "Uma biblioteca leve, de alta performance e sem dependências externas para manipulação de coleções de dados (arrays) em PHP, inspirada na sintaxe do LINQ (Language Integrated Query)",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Heliomar P. Marques",
      "email": "heliomarpm@gmail.com"
    }
  ],
  "keywords": [
    "linqphp",
    "linq",
    "linq2objects",
    "php-library",
    "collection",
    "array",
    "iterator",
    "yield"
  ],
  "autoload": {
    "psr-4": {
      "HeliomarPM\\LinqPHP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/phpunit --configuration phpunit.xml --colors=always",
    "test:v": "./vendor/bin/phpunit --configuration phpunit.xml --colors=always --debug",
    "bench": "php ./benchmark/run.php",
    "qa": [
      "@test",
      "@bench"
    ],
    "reset": "rm -rf vendor composer.lock && composer install && composer install"
  },
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.2"
  }
}
